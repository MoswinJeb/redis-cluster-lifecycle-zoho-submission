#!/bin/bash

set -e

check_prereqs() {

  echo "Checking prerequisites..."

  if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME="podman"
  elif command -v docker >/dev/null 2>&1; then
    CONTAINER_RUNTIME="docker"
  else
    echo "ERROR: Docker or Podman is required."
    echo "Install Docker: https://docs.docker.com/get-docker/"
    echo "Install Podman: https://podman.io/docs/installation"
    exit 1
  fi

  if ! command -v ansible >/dev/null 2>&1; then
    echo "ERROR: Ansible 2.14+ is required."
    echo "Install guide: https://docs.ansible.com/"
    exit 1
  fi

  ANSIBLE_VERSION=$(ansible --version | head -1 | awk '{print $3}' | tr -d ']')

  ANSIBLE_MAJOR=$(echo $ANSIBLE_VERSION | cut -d'.' -f1)
  ANSIBLE_MINOR=$(echo $ANSIBLE_VERSION | cut -d'.' -f2)

  if [ "$ANSIBLE_MAJOR" -lt 2 ] || \
     { [ "$ANSIBLE_MAJOR" -eq 2 ] && [ "$ANSIBLE_MINOR" -lt 14 ]; }; then

    echo "ERROR: Ansible 2.14+ is required."
    echo "Detected version: $ANSIBLE_VERSION"
    exit 1

  fi

  echo "✓ Container runtime found: $CONTAINER_RUNTIME"
  echo "✓ Ansible version found: $ANSIBLE_VERSION"

  echo
}

run_playbook() {
  cd ansible
  ansible-playbook "$@"
  cd ..
}

COMMAND=$1

check_prereqs

case $COMMAND in

    provision)

    REDIS_VERSION="7.0.15"
    MASTERS="3"
    REPLICAS_PER_MASTER="1"

    shift

    while [[ $# -gt 0 ]]; do

      case $1 in

        --version)
          REDIS_VERSION="$2"
          shift 2
          ;;

        --masters)
          MASTERS="$2"
          shift 2
          ;;

        --replicas-per-master)
          REPLICAS_PER_MASTER="$2"
          shift 2
          ;;

        *)
          echo "Unknown option: $1"
          exit 1
          ;;

      esac

    done

    if [ "$MASTERS" != "3" ] || [ "$REPLICAS_PER_MASTER" != "1" ]; then

      echo "This implementation currently supports:"
      echo "--masters 3 --replicas-per-master 1"
      exit 1

    fi

    echo "Provisioning Redis Cluster..."
    echo "Redis version: $REDIS_VERSION"
    echo "Masters: $MASTERS"
    echo "Replicas per master: $REPLICAS_PER_MASTER"

    run_playbook playbooks/provision.yml \
      -e redis_version=$REDIS_VERSION

    run_playbook playbooks/create_cluster.yml

    echo
    echo "Final Cluster Topology:"
    run_playbook playbooks/status.yml
    ;;

  data)

    SUBCOMMAND=$2

    case $SUBCOMMAND in

      seed)

        KEY_COUNT="1000"

        shift 2

        while [[ $# -gt 0 ]]; do

          case $1 in

            --keys)
              KEY_COUNT="$2"
              shift 2
              ;;

            *)
              echo "Unknown option: $1"
              exit 1
              ;;

          esac

        done

        echo "Seeding Redis data..."
        echo "Key count: $KEY_COUNT"

        run_playbook playbooks/data_seed.yml \
          -e key_count=$KEY_COUNT
        ;;

      verify)

        if [ "$3" == "--full" ]; then

          echo "Running full cluster verification..."

          run_playbook playbooks/verify_full.yml

          echo
          echo "FULL VERIFICATION COMPLETE"

        else

          echo "Running data verification..."

          run_playbook playbooks/data_verify.yml

        fi
        ;;

      *)

        echo "Usage:"
        echo "./redis-tool data seed"
        echo "./redis-tool data verify"
        echo "./redis-tool data verify --full"
        exit 1
        ;;

    esac
    ;;

  verify)

    if [ "$2" == "--full" ]; then

      echo "Running full cluster verification..."

      run_playbook playbooks/verify_full.yml

      echo
      echo "FULL VERIFICATION COMPLETE"

    else

      echo "Usage:"
      echo "./redis-tool verify --full"
      exit 1

    fi
    ;;

  status)

    run_playbook playbooks/status.yml
    ;;

  precheck)

    run_playbook playbooks/upgrade_precheck.yml
    ;;

  failover)

    REPLICA=$2

    if [ -z "$REPLICA" ]; then
      echo "Usage: ./redis-tool failover <replica-node>"
      exit 1
    fi

    run_playbook playbooks/failover.yml \
      -e target_replica=$REPLICA
    ;;

  upgrade-node)

    NODE=$2
    IP=$3
    VERSION=$4

    if [ -z "$NODE" ] || [ -z "$IP" ] || [ -z "$VERSION" ]; then
      echo "Usage: ./redis-tool upgrade-node <node> <ip> <version>"
      exit 1
    fi

    run_playbook playbooks/upgrade_node.yml \
      -e target_node=$NODE \
      -e node_ip=$IP \
      -e redis_version=$VERSION
    ;;

  upgrade)

    TARGET_VERSION=""
    STRATEGY=""

    shift

    while [[ $# -gt 0 ]]; do

      case $1 in

        --target-version)
          TARGET_VERSION="$2"
          shift 2
          ;;

        --strategy)
          STRATEGY="$2"
          shift 2
          ;;

        *)
          echo "Unknown option: $1"
          exit 1
          ;;

      esac

    done

    if [ -z "$TARGET_VERSION" ] || [ -z "$STRATEGY" ]; then
      echo "Usage:"
      echo "./redis-tool upgrade --target-version 7.2.6 --strategy rolling"
      exit 1
    fi

    if [ "$STRATEGY" != "rolling" ]; then
      echo "Only rolling strategy is supported."
      exit 1
    fi

    echo "Starting rolling upgrade to Redis $TARGET_VERSION"

    echo
    echo "[1/6] Running prechecks..."
    ./redis-tool precheck

    VERSION_CHECK=$(cd ansible && ansible redis \
      -m shell \
      -a "redis-server --version | awk '{print \$3}' | cut -d'=' -f2" \
      | grep Redis | awk '{print $NF}' | sort | uniq)

    VERSION_COUNT=$(echo "$VERSION_CHECK" | wc -l)

    if [ "$VERSION_COUNT" -eq 1 ] && [ "$VERSION_CHECK" = "$TARGET_VERSION" ]; then

      echo
      echo "Cluster already running Redis $TARGET_VERSION"
      echo "Skipping rolling upgrade steps."

    else

      echo
      echo "[2/6] Upgrading replicas first..."

      echo
      echo "Upgrading replica redis-node-4"
      ./redis-tool upgrade-node redis-node-4 10.10.0.14 $TARGET_VERSION

      echo
      echo "Upgrading replica redis-node-5"
      ./redis-tool upgrade-node redis-node-5 10.10.0.15 $TARGET_VERSION

      echo
      echo "Upgrading replica redis-node-6"
      ./redis-tool upgrade-node redis-node-6 10.10.0.16 $TARGET_VERSION

      echo
      echo "[3/6] Promoting upgraded replicas when needed..."

      for replica in redis-node-4 redis-node-5 redis-node-6
      do

        ROLE=$(cd ansible && ansible $replica \
          -m shell \
          -a "redis-cli INFO replication | grep role | cut -d':' -f2" \
          | grep -v SUCCESS | tail -1 | tr -d '\r')

        if [ "$ROLE" = "slave" ]; then

          echo
          echo "Failing over $replica"
          ./redis-tool failover $replica

        else

          echo
          echo "$replica already master — skipping failover"

        fi

      done

      echo
      echo "[4/6] Upgrading remaining nodes..."

      echo
      echo "Upgrading redis-node-1"
      ./redis-tool upgrade-node redis-node-1 10.10.0.11 $TARGET_VERSION

      echo
      echo "Upgrading redis-node-2"
      ./redis-tool upgrade-node redis-node-2 10.10.0.12 $TARGET_VERSION

      echo
      echo "Upgrading redis-node-3"
      ./redis-tool upgrade-node redis-node-3 10.10.0.13 $TARGET_VERSION

    fi
    echo 
    echo "Waiting for synchronization..."
    sleep 15
   
    echo
    echo "[5/6] Running full verification..."
    ./redis-tool verify --full

    echo
    echo "[6/6] Final cluster status..."
    ./redis-tool status

    echo
    echo "UPGRADE COMPLETE — all nodes upgraded to Redis $TARGET_VERSION"
    ;;

  *)

    echo "Usage:"
    echo "./redis-tool provision --version 7.0.15 --masters 3 --replicas-per-master 1"
    echo "./redis-tool data seed --keys 1000"
    echo "./redis-tool data verify"
    echo "./redis-tool verify --full"
    echo "./redis-tool status"
    echo "./redis-tool precheck"
    echo "./redis-tool failover <replica-node>"
    echo "./redis-tool upgrade-node <node> <ip> <version>"
    echo "./redis-tool upgrade --target-version 7.2.6 --strategy rolling"
    exit 1
    ;;

esac
